PORT=3000

# Banco de dados (use "db" quando rodar via Docker Compose)
DB_HOST=db
DB_USER=root
DB_PASS=sua_senha_aqui
DB_NAME=forca

# Segurança
JWT_SECRET=sua_chave_jwt_aqui

# OpenAI (necessário para geração de palavras com IA)
OPENAI_API_KEY=sk-...sua_chave_openai_aqui

# GCP Deploy (configurar como GitHub Secrets para CI/CD)
# GCP_HOST=ip_da_vm_gcp
# GCP_USER=seu_usuario
# GCP_SSH_KEY=conteudo_da_chave_privada